{
  "name": "creator-trust-lens",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "description": "Transparent Instagram engagement trust analysis in Chrome.",
  "scripts": {
    "postinstall": "wxt prepare",
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run typecheck && npm run test && npm run build",
    "release:check": "npm run check && npm audit --omit=dev && npm run zip"
  },
  "dependencies": {
    "jspdf": "^4.2.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "1.2.2",
    "typescript": "5.9.3",
    "vitest": "4.1.10",
    "wxt": "0.20.27"
  }
}
